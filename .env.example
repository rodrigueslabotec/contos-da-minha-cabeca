# === Database (MySQL - Railway Plugin) ===
# After adding MySQL plugin, Railway sets this automatically
DATABASE_URL=

# === App Config ===
JWT_SECRET=<gerar-um-segredo-aleatorio>
VITE_APP_ID=contos-da-minha-cabeca
NODE_ENV=production
PORT=3000
VITE_FRONTEND_URL=<url-do-railway>

# === Auth Bypass (TESTING ONLY - sem OAuth) ===
# Define AUTH_BYPASS=true e AUTH_BYPASS_PASSWORD=<senha> para ativar login local
# Usuários se registram diretamente sem precisar de OAuth externo
AUTH_BYPASS=false
AUTH_BYPASS_PASSWORD=

# === OAuth (OPCIONAL - sem isso login não funciona) ===
OAUTH_SERVER_URL=
VITE_OAUTH_PORTAL_URL=
OWNER_OPEN_ID=

# === Mercado Pago (OPCIONAL) ===
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_USER_ID=

# === Forge Storage (OPCIONAL - sem isso uploads/capas não funcionam) ===
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# === Analytics (OPCIONAL) ===
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
